{
  "name": "gmv-agent",
  "version": "0.2.0",
  "description": "GMV Agent — A Rust-powered personal AI assistant (Node.js bindings)",
  "main": "js/index.js",
  "types": "js/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMV-AI/gmv-agent"
  },
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "personal-assistant",
    "llm",
    "rust",
    "napi"
  ],
  "bin": {
    "gmv-agent": "js/cli.js"
  },
  "files": [
    "js/**/*.js",
    "js/**/*.d.ts",
    "*.node"
  ],
  "napi": {
    "name": "gmv-agent",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node --test ../tests/node/unit/*.test.mjs ../tests/node/integration/*.test.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  }
}
