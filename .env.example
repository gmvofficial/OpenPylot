# ===========================================
# GMV Agent - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider (choose one or both) ---
# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Default LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# Model to use (defaults: gpt-4o for OpenAI, claude-sonnet-4-20250514 for Anthropic)
LLM_MODEL=

# --- Google Calendar (OAuth2) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Port for OAuth2 callback (default: 8085)
GOOGLE_REDIRECT_PORT=8085

# --- Telegram ---
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Default chat ID to send messages to
TELEGRAM_DEFAULT_CHAT_ID=

# --- WhatsApp (via Twilio) ---
# Get from https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=  # e.g., whatsapp:+14155238886

# --- Agent Settings ---
AGENT_NAME=GMV Agent
AGENT_PERSONA=helpful, concise, professional
